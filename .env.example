# Copy to .env and fill in to move from mock/stubbed integrations to live ones.
# Every integration below auto-detects its keys at startup: set them and the
# pipeline calls the real API; leave them blank and it transparently falls
# back to deterministic mock data/logging, with zero code changes required.
# A failed live call (bad key, rate limit, outage) also falls back to the
# mock for that lead rather than breaking the run.

# Where leads/alerts persist. One SQLite file, but data is scoped per
# tenant -- a single self-hosted buyer needs nothing else here. To run one
# shared instance for multiple customers instead, provision each one with
# `cd backend && python scripts/create_tenant.py "Customer Name"`; they
# authenticate with the printed API key, everyone else (no key) still gets
# the zero-config default tenant.
DATABASE_PATH=data/app.db

# "text" (human-readable, local dev) or "json" (one JSON object per stdout
# line, for log aggregators when this runs in a container).
LOG_FORMAT=text

# Real Claude LLM scoring + outreach drafting (falls back to a mock assessment if unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Firmographic enrichment via Apollo.io organization-enrichment API
APOLLO_API_KEY=

# CRM push — HubSpot's custom company properties (fit_score, combined_score,
# lead_bucket, llm_rationale, outreach_draft) are auto-created on first push.
# Salesforce's matching custom Lead fields are best-effort auto-created via
# the Tooling API (needs "Customize Application" on the API user); see
# services/crm.py header for the fallback behavior if that permission is missing.
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# Slack alerts — posts to SLACK_CHANNEL_ID via slack_sdk when both are set.
# Needs the chat:write scope, and the bot must be invited to the channel
# (/invite @<bot-name> in Slack) — a preflight check logs a clear warning
# on first alert if either is missing, instead of a generic API error.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Frontend origin(s) allowed to call this API, comma-separated. Defaults to
# the local Vite dev server — a production deploy MUST set this to its real
# frontend origin(s) or the browser will block every request.
CORS_ALLOWED_ORIGINS=http://localhost:5000

# --- Licensing (buyer side — set these in a deployment you SELL/self-host) ---
# Issued after purchase (see licensing/README.md). Verified offline.
LICENSE_KEY=
LICENSE_PUBLIC_KEY=
# When true, /api/leads/upload 402s immediately without a valid LICENSE_KEY,
# skipping TRIAL_DAYS below entirely. Leave false (default) to give a fresh
# deployment TRIAL_DAYS of full-functionality evaluation first.
LICENSE_REQUIRED=false
# How many days of unlicensed use before /api/leads/upload starts 402ing.
# The clock starts on this deployment's first request, persisted to the same
# SQLite file as everything else (survives restarts).
TRIAL_DAYS=3

# --- Licensing & billing (seller side — only the seller's storefront needs these) ---
# Paddle (not Stripe) — a merchant-of-record, so it handles sales tax/VAT for
# you and its seller-eligibility list is broader than Stripe's (notably
# covers sellers Stripe doesn't). Card, PayPal, Apple Pay, and Google Pay all
# show up automatically on Paddle's hosted checkout for eligible buyers;
# enable PayPal once in the Paddle dashboard under Checkout > Payment
# methods if it isn't on already. See licensing/README.md for full setup.
LICENSE_PRIVATE_KEY=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Client-side token (Paddle dashboard: Developer Tools > Authentication >
# Client-side tokens tab — different, non-secret credential from
# PADDLE_API_KEY). Powers GET /api/billing/config, which the frontend reads
# to open Paddle.js's overlay checkout directly in the browser. Safe to
# expose; it can't create charges or read account data.
PADDLE_CLIENT_TOKEN=
# "sandbox" (default — a separate test account/API host, no real charges) or
# "production". Switch only once you've tested a full purchase in sandbox.
PADDLE_ENVIRONMENT=sandbox
# Two recurring Paddle Prices (format pri_...) on the same product —
# suggested: $30/mo, ~$300/yr (2 months free) as the annual discount. See
# licensing/README.md for how to create both in the Paddle dashboard.
PADDLE_PRICE_ID_MONTHLY=
PADDLE_PRICE_ID_ANNUAL=
# Licenses expire this many days out and are renewed on every
# transaction.completed webhook (fires for both the first payment and every
# renewal) — bounds how long a cancelled/failed subscriber's last-issued key
# keeps working, since an offline key can't be actively revoked. Separate
# windows because "a bit longer than one billing period" differs a lot
# between the two plans.
LICENSE_VALIDITY_DAYS_MONTHLY=35
LICENSE_VALIDITY_DAYS_ANNUAL=380

# Emails issued license keys to buyers automatically. Without either of
# these set, keys are still issued and logged to
# licensing/issued_licenses.jsonl — send them by hand instead. SendGrid is
# tried first if configured, SMTP is the fallback.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
